// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Tabla para los usuarios
model User {
  id        Int @id @default(autoincrement())
  email     String @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
}

// Tabla para el catalogo especies
model Species {
  id             Int @id  @default(autoincrement())
  commonName     String   @map("common_name")
  scientificName String?  @map("scientific_name")
  group          String // Ej: Mamífero, Ave, Reptil
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")

  // Aquí se establece la relación 1-n : Una especie - avistamentos
  sightings      Sighting[]

  @@map("species") // Se asigna al modelo un nombre diferente en MySQL
}

// Tabla para el registro de avistamentos de fauna
model Sighting {
  id         Int      @id @default(autoincrement())
  quantity   Int      @default(1)
  latitude   Float
  longitude  Float
  observedAt DateTime @default(now()) @map("observed_at")
  status     String   @default("vivo") // vivo, herido, muerto
  notes      String?  @db.Text
  photoPath  String   @map("photo_path")

  // Relación con especies
  species    Species  @relation(fields: [speciesId], references: [id])
  speciesId  Int      @map("species_id")

  @@map("sightings") // Se asigna al modelo un nombre diferente en MySQL
}